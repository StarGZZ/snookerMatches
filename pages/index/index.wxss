.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
}

.source {
  padding: 0 30rpx 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.source-hint {
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  margin-left: 10rpx;
}



/* 选项卡样式 */
.tab-container {
  display: flex;
  padding: 0 30rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: #ffffff;
  border-bottom-color: #ffffff;
  font-weight: bold;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.refresh-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.refresh-text {
  font-size: 26rpx;
  color: #ffffff;
}



.match-list {
  padding: 0 20rpx;
}

.match-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.match-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-upcoming {
  background: #f6ffed;
  color: #52c41a;
}

.status-finished {
  background: #f5f5f5;
  color: #8c8c8c;
}

.match-date {
  font-size: 24rpx;
  color: #999;
}

.match-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.match-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}
